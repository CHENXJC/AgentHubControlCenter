  "field_definitions": {
    "agent_id": "Stable lowercase identifier used by AgentHubControlCenter.",
    "agent_name": "Human-readable Agent or Skill name.",
    "category": "Portfolio category such as Media Intelligence, Workflow Automation, or Knowledge Base.",
    "description": "Short capability statement for the tool.",
    "project_path": "Local Windows project path.",
    "status": "Planned, Active, Complete, or Paused.",
    "inputs": "List of expected local inputs or manual context items.",
    "outputs": "List of outputs the tool can produce.",
    "actions": "List of HUB-V2-005 action schema objects for display, manual instruction, templates, links, report views, Codex prompts, or future connector placeholders.",
    "connectors": "List of local, link-based, demo, or future connectors.",
    "demo_mode": "True when the Agent is operating with demo/static/local data.",
    "safe_mode": "True when external actions and credential reads are disabled.",
    "last_run": "Last recorded local run time, or Not tracked yet.",
    "next_recommended_action": "Next safe action to show in Action Center.",
    "github_repo": "Optional GitHub showcase URL.",
    "dashboard_url": "Optional local or public dashboard URL.",
    "tags": "Optional labels such as Python, Streamlit, OCR, or Workflow Automation.",
    "owner": "Optional owner or maintainer label.",
    "public_showcase_status": "Optional GitHub/public showcase status.",
    "pin_status": "Optional GitHub profile pin status."
  },
